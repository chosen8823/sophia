      "path": "C:\\Users\\chose",
      "label": "Host Home",
      "kind": "local-host-root",
      "role": "Workspace envelope and user profile shell",
      "trust": "mixed",
      "scanPolicy": {
        "mode": "metadata-only",
        "maxDepth": 1,
        "followReparsePoints": false,
        "includeHidden": false

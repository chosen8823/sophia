    {
      "id": "web",
      "label": "Web Cache",
      "kind": "projection",
      "path": "./state/web-cache",
      "status": "ready",
      "latency": "fast",
      "role": "Browser-facing working copy"
    },
    {
      "id": "container",
      "label": "Container Mount",
      "kind": "runtime",
      "path": "/cartridge/state",

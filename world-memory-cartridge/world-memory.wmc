        "mode": "metadata-only",
        "maxDepth": 1,
        "followReparsePoints": false,
        "includeHidden": false
      },
      "anchors": [
        "Restic",
        "repos",
        "OneDrive_Migrated-20251226-135104",
        "Installers"
      ],
      "cautions": [
        "Treat migrated OneDrive copies as historical shadow, not live canonical repos",
        "Backups and installers should stay classified separately from active working memory"
      ]
    }
  ],
  "mirrors": [
    {
      "id": "local",
      "label": "Local World",
      "kind": "ground truth",
      "path": "./state/local-world",
      "status": "primary",
      "latency": "near-zero",
      "role": "Canonical editable memory root"

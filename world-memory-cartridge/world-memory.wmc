    "container": {
      "command": "docker compose up --build",
      "serves": "http://127.0.0.1:4033",
      "volume": "./state:/cartridge/state"
    }
  },
  "swarm": {
    "middleware": "./middleware/agent-middleware.json",
    "mode": "specialist routing",
    "queueRoots": {
      "inbox": "./state/local-world/inbox",
      "outbox": "./state/local-world/outbox",
      "receipts": "./state/local-world/receipts",
      "swarm": "./state/local-world/swarm"

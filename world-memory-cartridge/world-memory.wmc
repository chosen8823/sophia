{
  "format": {
    "name": "World Memory Cartridge",
    "extension": ".wmc",
    "encoding": "utf-8",
    "payload": "json"
  },
  "name": "World Memory Cartridge",
  "version": "0.2.0",
  "generatedFrom": "local-first prototype",
  "description": "A mirrored cartridge that models unlimited memory as a nested world with local, cloud, web, and container projections.",
  "projectionCore": {
    "label": "Projection Core",
    "intent": "Give the agent a central place to project from while keeping every mirror inspectable.",
    "mode": "nested geometry",
    "worldRule": "Memory is layered, not singular."
  },
  "specs": {
    "computeFabric": "Elastic multi-agent field",
    "memoryModel": "World-backed and appendable",
    "middlewareModel": "File-backed swarm router",
    "memoryLimit": "Unlimited by model, bounded only by storage policy",
    "specialistCount": 5,
    "projectionTargets": [
      "local",
      "cloud",
      "web",
      "container"
    ],
    "defaultPort": 4033
  },
  "paths": {
    "projectRoot": ".",
    "artifact": "./world-memory.wmc",
    "manifest": "./memory-manifest.json",
    "middleware": "./middleware/agent-middleware.json",
    "knowledgeSources": "./sources/knowledge-sources.json",
    "discoveredMemoryPaths": "./sources/discovered-memory-paths.json",
    "swarmRoot": "./state/local-world/swarm",
    "localRoot": "./state/local-world",
    "cloudMirrorRoot": "./state/cloud-shadow",
    "webProjectionRoot": "./state/web-cache",
    "containerMountRoot": "/cartridge/state"
  },

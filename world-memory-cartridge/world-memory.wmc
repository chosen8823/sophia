        "Contains hidden and system profile state",
        "Contains OneDrive sync surface; do not treat as purely local ground truth",
        "Contains known broken loose fragment files in the root; do not semantic-index by default"
      ]
    },
    {
      "id": "downloads-staging",
      "path": "C:\\Users\\chose\\Downloads",
      "label": "Downloads Staging",
      "kind": "ingress-root",
      "role": "Landing zone for imports, exports, archives, briefs, and ad hoc assets",
      "trust": "mixed",
      "scanPolicy": {
        "mode": "metadata-only",
        "maxDepth": 1,
        "followReparsePoints": false,
        "includeHidden": false
      },
      "anchors": [
        "database4",
        "CLAUDE_CLI_BUILD_BRIEF.md",
        "conversation zips",
        "SOPHIA and LLM archives"
